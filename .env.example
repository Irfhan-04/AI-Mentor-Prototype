# Copy this file to .env and fill in real values. Never commit .env.
GEMINI_API_KEY=

# Check https://ai.google.dev/gemini-api/docs/models for the current model
# list before setting this. There is no safe hardcoded default.
GEMINI_MODEL_NAME=

MENTOR_TEMPERATURE=0.4
MENTOR_MAX_OUTPUT_TOKENS=1024
MENTOR_REQUEST_TIMEOUT_S=30
MENTOR_LOG_LEVEL=INFO
